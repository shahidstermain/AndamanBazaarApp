VITE_FIREBASE_API_KEY=your_public_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

VITE_FIREBASE_CREATE_PAYMENT_FUNCTION=https://<region>-<project>.cloudfunctions.net/createPayment
VITE_FIREBASE_VERIFY_PAYMENT_FUNCTION=https://<region>-<project>.cloudfunctions.net/verifyPayment
VITE_FIREBASE_VERIFY_LOCATION_FUNCTION=https://<region>-<project>.cloudfunctions.net/verifyLocation
VITE_FIREBASE_MODERATE_CONTENT_FUNCTION=https://<region>-<project>.cloudfunctions.net/moderateContent
VITE_FIREBASE_CREATE_INVOICE_FUNCTION=https://<region>-<project>.cloudfunctions.net/createInvoice
VITE_FIREBASE_WEBHOOK_FUNCTION=https://<region>-<project>.cloudfunctions.net/handleWebhook
VITE_FIREBASE_HEALTH_FUNCTION=https://<region>-<project>.cloudfunctions.net/healthCheck
VITE_FIREBASE_SECURE_SYNC_FUNCTION=https://<region>-<project>.cloudfunctions.net/secureSync
VITE_FIREBASE_AI_SUGGEST_FUNCTION=https://<region>-<project>.cloudfunctions.net/aiSuggest

VITE_CASHFREE_ENV=sandbox
VITE_ENABLE_CSP=true
VITE_ENV=development

VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Cashfree Configuration (Production/Sandbox)
VITE_CASHFREE_ENV=sandbox
VITE_CASHFREE_PROD=false

# App Configuration
VITE_ENV=development
VITE_ENABLE_CSP=true
VITE_RATE_LIMIT_WINDOW=60000
VITE_RATE_LIMIT_MAX_REQUESTS=100
VITE_E2E_BYPASS_AUTH=false

# Note: Firebase variables are being retired.
# VITE_FIREBASE_API_KEY=your_public_firebase_web_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VERIFY_PAYMENT_FUNCTION=https://<region>-<project>.cloudfunctions.net/verifyPayment
VITE_FIREBASE_VERIFY_LOCATION_FUNCTION=https://<region>-<project>.cloudfunctions.net/verifyLocation
VITE_FIREBASE_MODERATE_CONTENT_FUNCTION=https://<region>-<project>.cloudfunctions.net/moderateContent
VITE_FIREBASE_CREATE_INVOICE_FUNCTION=https://<region>-<project>.cloudfunctions.net/createInvoice
VITE_FIREBASE_WEBHOOK_FUNCTION=https://<region>-<project>.cloudfunctions.net/handleWebhook
VITE_FIREBASE_AI_SUGGEST_FUNCTION=https://<region>-<project>.cloudfunctions.net/aiSuggest
VITE_FIREBASE_SEND_EMAIL_FUNCTION=https://<region>-<project>.cloudfunctions.net/sendEmail

VITE_CASHFREE_ENV=sandbox
VITE_ENABLE_CSP=true
VITE_ENV=development

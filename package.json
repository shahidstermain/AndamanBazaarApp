{
  "name": "andaman-bazaar",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:e2e": "playwright test",
    "test:security": "vitest run tests/security",
    "test:accessibility": "vitest run tests/accessibility --passWithNoTests",
    "test:performance": "lighthouse http://localhost:5173 --output=html --output-path=./reports/performance.html",
    "test:load": "k6 run tests/load/k6-script.js",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:visual": "playwright test tests/e2e/visual.spec.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:security && npm run test:accessibility",
    "test:ci": "npm run test:unit -- --coverage && npm run test:integration && npm run test:security",
    "test:watch": "vitest --watch",
    "test:affected": "vitest related --run",
    "lint": "eslint src tests --ext .ts,.tsx,.js,.jsx --fix",
    "lint:check": "eslint src tests --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write src tests \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check src tests \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "audit:fix": "npm audit fix",
    "pre-commit": "node scripts/pre-commit.js",
    "prepare": "husky install",
    "firebase-deploy": "npm run build && firebase deploy",
    "bundle-analyze": "npm run build && npx bundlesize",
    "lighthouse": "lighthouse http://localhost:5173 --output=html --output-path=./reports/lighthouse.html",
    "perf:matrix": "npm run build && npm run preview & sleep 10 && npm run test:performance",
    "security:scan": "npm audit && npm run test:security",
    "accessibility:scan": "npm run test:accessibility",
    "e2e:matrix": "playwright test --shard=1/3 && playwright test --shard=2/3 && playwright test --shard=3/3",
    "ci:test": "npm run test:ci && npm run lint:check && npm run format:check && npm run type-check",
    "ci:build": "npm run build && npm run bundle-analyze",
    "ci:deploy:staging": "npm run ci:build && firebase deploy --only hosting:staging",
    "ci:deploy:production": "npm run ci:build && firebase deploy --only hosting:production"
  },
  "dependencies": {
    "@google/generative-ai": "0.24.1",
    "@lovable.dev/cloud-auth-js": "0.0.3",
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-progress": "1.1.0",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-toast": "1.2.2",
    "@sentry/react": "^10.45.0",
    "@supabase/supabase-js": "2.45.0",
    "@types/dompurify": "3.0.5",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "daisyui": "5.5.19",
    "dequal": "2.0.3",
    "dompurify": "3.3.1",
    "embla-carousel-react": "8.6.0",
    "firebase": "^11.0.0",
    "jest-axe": "8.0.0",
    "lucide-react": "0.292.0",
    "opencode-antigravity-auth": "1.6.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "6.26.0",
    "recharts": "2.15.4",
    "sonner": "2.0.7",
    "tailwind-merge": "2.5.2",
    "tailwindcss-animate": "1.0.7",
    "vite-plugin-pwa": "1.2.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "14.3.1",
    "@testing-library/user-event": "14.6.1",
    "@types/deno": "^2.5.0",
    "@types/jest": "29.5.14",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "@vitejs/plugin-react": "4.3.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "10.4.24",
    "axe-core": "4.11.1",
    "bundlesize": "^0.18.1",
    "eslint": "8.57.1",
    "eslint-plugin-react-hooks": "4.6.2",
    "eslint-plugin-react-refresh": "0.4.26",
    "fake-indexeddb": "^4.0.2",
    "happy-dom": "^20.8.9",
    "husky": "^8.0.3",
    "lighthouse": "11.7.0",
    "lint-staged": "^15.2.0",
    "msw": "2.12.10",
    "playwright": "1.58.2",
    "postcss": "8.4.41",
    "prettier": "^3.1.0",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4",
    "vite": "5.4.21",
    "vitest": "^1.6.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "bundlesize": [
    {
      "path": "dist/index.html",
      "maxSize": "2kb"
    },
    {
      "path": "dist/assets/*.js",
      "maxSize": "250kb"
    },
    {
      "path": "dist/assets/*.css",
      "maxSize": "50kb"
    }
  ]
}

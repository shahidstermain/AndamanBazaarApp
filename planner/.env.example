# ─── Supabase (shared with AndamanBazaar) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://msxeqzceqjatoaluempo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only: service role key bypasses RLS for rate-limiting & admin writes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Google AI (Gemini) ──────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=your-gemini-api-key-here

# ─── Next.js deployment ──────────────────────────────────────────────────────
# Set to /planner when serving under a reverse-proxy subpath
NEXT_BASE_PATH=/planner
NEXTAUTH_URL=http://localhost:3001/planner

# ─── Rate limiting ───────────────────────────────────────────────────────────
PLANNER_MAX_GENERATIONS_PER_HOUR=5
